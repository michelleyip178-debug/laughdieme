# PostHog — get these from https://app.posthog.com (Project Settings → API keys)
# This is the public "Project API key" (write-only, safe to ship to the browser).
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_api_key_here
# US cloud: https://us.i.posthog.com  |  EU cloud: https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
